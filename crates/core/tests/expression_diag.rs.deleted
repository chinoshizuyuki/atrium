// Diagnostic for 2 E2E test failures
use atrium_emotion::EmotionState;
use atrium_memory::relationship::RelationshipStage;
use atrium_memory::style_modulator::ExpressionContext;
use atrium_core::expression_orchestrator::ExpressionOrchestrator;
use atrium_memory::subtext_engine::SubtextEngine;

#[tokio::test]
async fn diag_sad_coherence() {
    let sad_state = EmotionState::new(-0.6, -0.3, -0.2);
    let stage = RelationshipStage::Trusted {
        since: 0, interactions: 200, shared_references: 30, key_moments: 5,
    };
    let ctx = ExpressionContext::from_modules(
        &sad_state, None, atrium_emotion::EmotionDirection::SelfDirected,
        &stage, -0.4, 0.5,
    );
    let expr = ExpressionOrchestrator::orchestrate(&ctx, "我最近压力好大", [-0.6, -0.3, -0.2], 100);
    println!("=== Sad Scenario ===");
    println!("coherence: is_coherent={}, direction={}, arousal={}, dominance={}, speech_act={}",
        expr.coherence.is_coherent, expr.coherence.direction_consistent,
        expr.coherence.arousal_consistent, expr.coherence.dominance_consistent,
        expr.coherence.speech_act_consistent);
    println!("warnings: {:?}", expr.coherence.warnings);
}

#[tokio::test]
async fn diag_subtext_detection() {
    let pad = [-0.2f32, 0.1, 0.0];
    let stage = RelationshipStage::Deep {
        since: 0, interactions: 500, shared_references: 80, key_moments: 20,
    };
    let signals = SubtextEngine::detect("我没事", pad, &stage);
    println!("=== Subtext Detection ===");
    println!("SubtextEngine::detect signals: {}", signals.len());
    for s in &signals {
        println!("  category={:?}, confidence={:.3}, interpretation={}", s.category, s.confidence, s.interpretation);
    }

    let ctx = ExpressionContext::from_modules(
        &EmotionState::new(-0.2, 0.1, 0.0), None, atrium_emotion::EmotionDirection::SelfDirected,
        &stage, -0.2, 0.4,
    );
    let expr = ExpressionOrchestrator::orchestrate(&ctx, "我没事", [-0.2, 0.1, 0.0], 50);
    println!("\norchestrate subtext_signals: {}", expr.subtext_signals.len());
    for s in &expr.subtext_signals {
        println!("  kind={:?}, intensity={:.3}, express={}", s.kind, s.intensity, s.express_explicitly);
    }
}
