# Atrium — Environment Variables
# Copy this file to .env and fill in your values.
# All variables have safe defaults for local development.

# ─── LLM API ──────────────────────────────────────────────────
ATRIUM_LLM_API_KEY=
ATRIUM_LLM_BASE_URL=https://api.deepseek.com/v1
ATRIUM_LLM_MODEL=deepseek-chat
ATRIUM_LLM_TEMPERATURE=0.7
ATRIUM_LLM_MAX_TOKENS=1024

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=atrium
POSTGRES_PASSWORD=atrium
POSTGRES_DB=atrium

# ─── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=

# ─── Grafana ──────────────────────────────────────────────────
GRAFANA_PASSWORD=atrium

# ─── Gateway ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
