# Atrium Gateway — Python Control Plane
# Multi-stage: builder (deps + gRPC stubs) + runtime (slim)

FROM python:3.13-slim AS builder
WORKDIR /app
# Copy source for pip install (resolves deps from pyproject.toml)
COPY services/llm-orchestrator/ /app/services/llm-orchestrator/
COPY services/gateway/ /app/services/gateway/
# Install from pyproject.toml — keeps deps in sync automatically
RUN pip install --no-cache-dir --prefix=/install \
    /app/services/llm-orchestrator/ \
    /app/services/gateway/ \
    httpx  # needed for healthcheck at runtime
# Generate gRPC stubs (atrium_pb2.py etc. are gitignored, must regenerate)
RUN pip install --no-cache-dir grpcio-tools protobuf && \
    python /app/services/gateway/gen_proto.py && \
    cp -r /app/services/gateway/atrium/ /install/lib/python3.13/site-packages/atrium/

FROM python:3.13-slim
WORKDIR /app
# Create non-root user for security
RUN groupadd -r atrium && useradd -r -g atrium -d /app -s /sbin/nologin atrium
# Copy installed packages from builder (includes gRPC stubs)
COPY --from=builder /install /usr/local
# Copy application code
COPY services/gateway/ /app/gateway/
COPY services/llm-orchestrator/ /app/llm-orchestrator/
# Frontend static files (optional — user provides UI later)
COPY frontend/ /app/frontend/
RUN mkdir -p /app/data \
    && chown -R atrium:atrium /app
ENV PYTHONPATH=/app/llm-orchestrator:/app/gateway
USER atrium
EXPOSE 8080
# Healthcheck: verify /health endpoint responds
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
  CMD python -c "import httpx; r=httpx.get('http://localhost:8080/health', timeout=5); r.raise_for_status()" || exit 1
CMD ["python", "-m", "uvicorn", "atrium.app:app", "--host", "0.0.0.0", "--port", "8080"]
